ENV=dev                          # dev | prod
ALLOW_DEV_USER_FALLBACK=true
# Prefer setting a real auth.users UUID here in development.
# If empty and ALLOW_DEV_USER_FALLBACK=true, the backend will generate a runtime UUID
# and try to create a development auth user automatically.
DEV_USER_ID=
DEV_USER_EMAIL=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI
OPENAI_API_KEY=sk-...

# Supabase
# Project URL: Supabase 대시보드 → Settings → API → Project URL
SUPABASE_URL=https://xxxx.supabase.co
# anon public key: Supabase 대시보드 → Settings → API → anon public
SUPABASE_KEY=sb_publishable_...
# Connection string: Supabase 대시보드 → Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres
